# MindCare AI Symfony - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Application
APP_ENV=dev
APP_DEBUG=true
APP_SECRET=your_secret_key_here

# Database
DATABASE_URL=mysql://user:password@127.0.0.1:3306/mindcare_ai

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# Email (if applicable)
MAILER_DSN=smtp://localhost:1025

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Debug
DEBUG=false